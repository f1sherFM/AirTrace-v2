SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=airtrace-v2

ALERTS_API_KEY=change-me
TELEGRAM_BOT_TOKEN=change-me

REDIS_URL=redis://redis:6379/0
POSTGRES_DB=airtrace
POSTGRES_USER=airtrace
POSTGRES_PASSWORD=change-me
DATABASE_RUN_MIGRATIONS_ON_STARTUP=true
HISTORY_STORAGE_BACKEND=database
DATABASE_URL=postgresql+asyncpg://airtrace:change-me@db:5432/airtrace
